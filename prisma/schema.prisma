generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STAFF
}

enum DeliveryMethod {
  PICKUP
  DELIVERY
  COURIER
}

enum OrderStage {
  NEW
  CONFIRMED
  DESIGN_PENDING
  DESIGN_SENT
  DESIGN_APPROVED
  IN_PRODUCTION
  READY_TO_PACK
  PACKED
  PICKUP_READY
  SHIPPED
  DELIVERED
  ON_HOLD
  CANCELLED
  RETURNED
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  REFUNDED
}

enum PaymentType {
  ADVANCE
  ADDITIONAL
  FINAL_PAYMENT
  DELIVERY_COLLECTION
  REFUND
  ADJUSTMENT
}

enum PaymentMethod {
  CASH
  ESEWA
  KHALTI
  FONEPAY
  BANK_TRANSFER
  COD
  OTHER
}

enum PrintType {
  LABEL
  BULK_LABEL
  REPRINT
}

model User {
  id                    String               @id @default(cuid())
  name                  String
  email                 String               @unique
  phone                 String?
  passwordHash          String
  role                  Role                 @default(STAFF)
  isActive              Boolean              @default(true)
  refreshTokenVersion   Int                  @default(0)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  bookedOrders          Order[]              @relation("BookedOrders")
  receivedPayments      Payment[]            @relation("ReceivedPayments")
  statusChanges         OrderStatusHistory[] @relation("StatusChanges")
  printLogs             PrintLog[]           @relation("PrintLogs")
  auditLogs             AuditLog[]           @relation("AuditActor")
}

model Customer {
  id               String   @id @default(cuid())
  name             String
  primaryPhone     String
  normalizedPhone  String   @unique
  alternativePhone String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  orders           Order[]

  @@index([name])
  @@index([primaryPhone])
}

model Product {
  id           String      @id @default(cuid())
  name         String
  productType  String
  defaultPrice Decimal     @db.Decimal(12, 2)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  orderItems   OrderItem[]

  @@index([productType])
}

model OrderSource {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Order {
  id                   String               @id @default(cuid())
  orderNumber          String               @unique
  legacyOrderId        String?              @unique
  customerId           String
  customer             Customer             @relation(fields: [customerId], references: [id])
  orderDate            DateTime             @default(now())
  quantity             Int
  subtotal             Decimal              @db.Decimal(12, 2)
  discount             Decimal              @default(0) @db.Decimal(12, 2)
  deliveryCharge       Decimal              @default(0) @db.Decimal(12, 2)
  totalPrice           Decimal              @db.Decimal(12, 2)
  amountPaid           Decimal              @default(0) @db.Decimal(12, 2)
  remainingBalance     Decimal              @default(0) @db.Decimal(12, 2)
  deliveryMethod       DeliveryMethod
  deliveryAddress      String?
  pickupLocation       String?
  requiredDeliveryAt   DateTime?
  followUpAt           DateTime?
  specialNotes         String?
  sourceId             String?
  source               OrderSource?         @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  orderStage           OrderStage           @default(NEW)
  paymentStatus        PaymentStatus        @default(UNPAID)
  bookedByUserId       String
  bookedBy             User                 @relation("BookedOrders", fields: [bookedByUserId], references: [id])
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  cancelledAt          DateTime?
  cancellationReason   String?
  items                OrderItem[]
  payments             Payment[]
  statusHistory        OrderStatusHistory[]
  printLogs            PrintLog[]
  auditLogs            AuditLog[]

  @@index([orderDate])
  @@index([orderStage])
  @@index([paymentStatus])
  @@index([deliveryMethod])
  @@index([requiredDeliveryAt])
  @@index([followUpAt])
  @@index([sourceId])
}

model OrderItem {
  id                     String  @id @default(cuid())
  orderId                String
  order                  Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId              String?
  product                Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productNameSnapshot    String
  productType            String
  quantity               Int
  unitPrice              Decimal @db.Decimal(12, 2)
  lineTotal              Decimal @db.Decimal(12, 2)
  personalizationNotes   String?
}

model Payment {
  id               String        @id @default(cuid())
  orderId          String
  order            Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount           Decimal       @db.Decimal(12, 2)
  paymentType      PaymentType
  paymentMethod    PaymentMethod
  referenceNumber  String?
  receivedByUserId String
  receivedBy       User          @relation("ReceivedPayments", fields: [receivedByUserId], references: [id])
  notes            String?
  paidAt           DateTime      @default(now())
  createdAt        DateTime      @default(now())

  @@index([paidAt])
}

model OrderStatusHistory {
  id              String      @id @default(cuid())
  orderId         String
  order           Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  previousStatus  OrderStage?
  newStatus       OrderStage
  changedByUserId String
  changedBy       User        @relation("StatusChanges", fields: [changedByUserId], references: [id])
  notes           String?
  createdAt       DateTime    @default(now())
}

model PrintLog {
  id              String    @id @default(cuid())
  orderId         String
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  printedByUserId String
  printedBy       User      @relation("PrintLogs", fields: [printedByUserId], references: [id])
  printerName     String?
  printType       PrintType
  copyNumber      Int       @default(1)
  printedAt       DateTime  @default(now())
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation("AuditActor", fields: [userId], references: [id], onDelete: SetNull)
  orderId      String?
  order        Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  entityType   String
  entityId     String
  action       String
  previousData Json?
  newData      Json?
  createdAt    DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model DailyOrderSequence {
  dateKey   String @id
  lastValue Int    @default(0)
}

model LabelSetting {
  id             String   @id @default(cuid())
  name           String   @unique
  widthMm        Int      @default(48)
  heightMm       Int      @default(30)
  marginMm       Int      @default(2)
  fontSize       Int      @default(10)
  dpi            Int      @default(203)
  showAddress    Boolean  @default(true)
  showNotes      Boolean  @default(true)
  showBalance    Boolean  @default(true)
  showRequiredAt Boolean  @default(true)
  isDefault      Boolean  @default(true)
  updatedAt      DateTime @updatedAt
}
